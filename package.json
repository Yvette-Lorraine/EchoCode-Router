{
  "name": "echocode-router",
  "version": "0.1.0",
  "description": "智能 AI 网关路由层 — 顺位故障切换 · Key 池加权 · 灰度发布。零业务依赖。",
  "license": "MIT",
  "author": "Echo Code <visioncore@yuanjinghexin.cn>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yvette-Lorraine/EchoCode-Router.git"
  },
  "keywords": [
    "ai",
    "router",
    "网关",
    "gateway",
    "openai",
    "byok",
    "故障切换",
    "cascade",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'use biome'",
    "example": "tsx examples/standalone-server.ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@prisma/client": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  }
}
